{
  "name": "dbcompare",
  "version": "1.0.0",
  "description": "Compare data between SQLite and PostgreSQL databases",
  "main": "src/index.ts",
  "bin": {
    "dbcompare": "./bin/dbcompare.js"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc",
    "compare": "tsx src/cli.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.ts\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.ts\" \"*.json\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/sql.js": "^1.4.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,js}": [
      "prettier --write"
    ]
  }
}
